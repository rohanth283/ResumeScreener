{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/_/backend/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/(.*)",
      "continue": true
    }
  ]
}